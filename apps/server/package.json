{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "clean": "rm -rf build/ && rm -rf dist/",
    "tsoa:gen": "tsoa spec-and-routes",
    "dev": "nodemon --watch 'src/**/*.ts' --ignore 'src/routes.ts' --ext 'ts,json' --exec 'pnpm tsoa:gen && tsx src/server.ts'",
    "build": "pnpm tsoa:gen && tsc",
    "prestart": "pnpm build",
    "prestart:prod": "pnpm build",
    "start": "node dist/server.js",
    "start:prod": "node --env-file=.env.prod dist/server.js",
    "lint": "eslint --ext .ts,.js ."
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@tsoa/runtime": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^10.2.0",
    "eslint-config": "^0.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "nodemon": "^3.1.0",
    "prisma": "^7.7.0",
    "tsoa": "^6.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.58.2"
  }
}
